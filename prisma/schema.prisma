generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum EntryType {
  INCOME
  EXPENSE
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(VIEWER)
  isActive  Boolean    @default(true)
  records   Record[]
  auditLogs AuditLog[]
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Record {
  id        String    @id @default(uuid())
  amount    Decimal   @db.Decimal(12, 2)
  type      EntryType
  category  String
  date      DateTime
  notes     String?
  createdBy User      @relation(fields: [userId], references: [id])
  userId    String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, deletedAt, date])
  @@index([date])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     User     @relation(fields: [actorId], references: [id])
  actorId   String
  action    String
  targetId  String
  meta      Json?
  createdAt DateTime @default(now())
}
